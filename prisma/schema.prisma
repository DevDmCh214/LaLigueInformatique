// Schéma Prisma — La Ligue Informatique
// Base de données : SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Utilisateur ──────────────────────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // hash bcrypt
  name      String
  createdAt DateTime @default(now())

  teamMembers TeamMember[]
  rsvps       RSVP[]
}

// ── Équipe ───────────────────────────────────────────────────
model Team {
  id        Int      @id @default(autoincrement())
  name      String
  sport     String?
  createdAt DateTime @default(now())

  members TeamMember[]
  events  Event[]
}

// ── Membre d'équipe (N,N : User ↔ Team, porteuse de données) ─
// Fusionne l'ancien Player + TeamMember :
//   role     = rôle applicatif (admin / member)
//   position = poste sportif (gardien, attaquant…)
//   phone    = numéro de contact dans le contexte de l'équipe
model TeamMember {
  id       Int     @id @default(autoincrement())
  role     String  @default("member") // "admin" ou "member"
  position String? // poste sportif
  phone    String? // numéro de contact
  userId   Int
  teamId   Int
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

// ── Événement (1,N : Team → Event) ──────────────────────────
model Event {
  id          Int      @id @default(autoincrement())
  title       String
  type        String   // "game" ou "practice"
  date        DateTime
  location    String?
  opponent    String?
  description String?
  teamId      Int
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  rsvps RSVP[]
}

// ── RSVP (N,N : User ↔ Event, porteuse de données) ──────────
model RSVP {
  id      Int    @id @default(autoincrement())
  status  String // "going", "not_going", "maybe"
  userId  Int
  eventId Int
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}
