// Schema Prisma — La Ligue Informatique
// Conforme au MCD : Utilisateur, Sport, Equipe, Evenement, Match (heritage XT)
// Base de donnees : SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -- Utilisateur --
model Utilisateur {
  id     Int    @id @default(autoincrement())
  nom    String
  prenom String
  email  String @unique
  mdp    String // hash bcrypt
  role   String @default("utilisateur") // "admin" | "utilisateur"

  reponses       Reponse[]
  appartenances  Appartenir[]
  sportsInscrits SportInscription[]
  sessions       Session[]
  connexions     Connexion[]
}

// -- Session --
model Session {
  id            String   @id @default(uuid())
  utilisateurId Int
  ipAddress     String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  isActive      Boolean  @default(true)

  utilisateur Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)

  @@index([utilisateurId])
  @@index([expiresAt])
}

// -- Connexion (log des tentatives de login) --
model Connexion {
  id            Int      @id @default(autoincrement())
  ipAddress     String
  utilisateurId Int?
  attemptedAt   DateTime @default(now())
  success       Boolean  @default(false)

  utilisateur Utilisateur? @relation(fields: [utilisateurId], references: [id], onDelete: SetNull)

  @@index([ipAddress, attemptedAt])
  @@index([utilisateurId])
}

// -- AuditLog (journal de modifications) --
model AuditLog {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  utilisateurId Int?
  tableName     String
  action        String   // "INSERT" | "UPDATE" | "DELETE"
  recordId      String
  oldState      String?  // JSON
  newState      String?  // JSON
}

// -- Sport --
model Sport {
  id  Int    @id @default(autoincrement())
  nom String @unique

  equipes      Equipe[]
  evenements   Evenement[]
  inscriptions SportInscription[]
}

// -- Equipe --
model Equipe {
  id           Int    @id @default(autoincrement())
  nom          String
  nombrePlaces Int
  sportId      Int

  sport          Sport                @relation(fields: [sportId], references: [id], onDelete: Cascade)
  membres        Appartenir[]
  participations EquipeParticipante[]
  matchsGagnes   Match[]              @relation("EquipeGagnante")
}

// -- Evenement (classe parente) --
model Evenement {
  id           Int      @id @default(autoincrement())
  participants Int
  entitule     String
  dateHeure    DateTime
  description  String?
  sportId      Int

  sport    Sport     @relation(fields: [sportId], references: [id], onDelete: Cascade)
  reponses Reponse[]
  match    Match?
}

// -- Match (herite de Evenement — XT) --
model Match {
  id               Int  @id @default(autoincrement())
  evenementId      Int  @unique
  equipeGagnanteId Int?

  evenement            Evenement            @relation(fields: [evenementId], references: [id], onDelete: Cascade)
  equipeGagnante       Equipe?              @relation("EquipeGagnante", fields: [equipeGagnanteId], references: [id], onDelete: SetNull)
  equipesParticipantes EquipeParticipante[]
}

// -- Reponse (N,N : Utilisateur <-> Evenement) --
model Reponse {
  id            Int    @id @default(autoincrement())
  reponse       String // "present" | "absent" | "peut-etre"
  utilisateurId Int
  evenementId   Int

  utilisateur Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  evenement   Evenement   @relation(fields: [evenementId], references: [id], onDelete: Cascade)

  @@unique([utilisateurId, evenementId])
}

// -- Appartenir (N,N : Utilisateur <-> Equipe) --
model Appartenir {
  id            Int @id @default(autoincrement())
  utilisateurId Int
  equipeId      Int

  utilisateur Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  equipe      Equipe      @relation(fields: [equipeId], references: [id], onDelete: Cascade)

  @@unique([utilisateurId, equipeId])
}

// -- EquipeParticipante (N,N : Match <-> Equipe, card. 2,2) --
model EquipeParticipante {
  id       Int @id @default(autoincrement())
  matchId  Int
  equipeId Int

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  equipe Equipe @relation(fields: [equipeId], references: [id], onDelete: Cascade)

  @@unique([matchId, equipeId])
}

// -- SportInscription (N,N : Utilisateur <-> Sport) --
model SportInscription {
  id            Int @id @default(autoincrement())
  utilisateurId Int
  sportId       Int

  utilisateur Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  sport       Sport       @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([utilisateurId, sportId])
}
